# Required environment variables for verdant-command-center-preview
# All variables are VITE_-prefixed and safe for client-side exposure.
#
# ⚠️  NEVER add SUPABASE_SERVICE_ROLE_KEY or any secret key here.
#     Only anon/publishable keys are permitted in client builds.

VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-anon-key>"
VITE_SUPABASE_PROJECT_ID="<supabase-project-ref>"

# ──────────────────────────────────────────────────────────────────────────────
# Paddle (SANDBOX ONLY)
# ──────────────────────────────────────────────────────────────────────────────
# Verdant is in sandbox/test mode for Paddle. Live charges are NOT enabled.
# Until live verification is complete, VITE_PADDLE_ENVIRONMENT MUST be "sandbox".
# The client-side checkout helper refuses to initialize if it is set to
# "live" or "production".
#
# VITE_PADDLE_CLIENT_TOKEN is a publishable client-side token (not a secret
# API key). It is safe for client builds. Do NOT put PADDLE_API_KEY or
# PADDLE_WEBHOOK_SECRET in this file — those are server-only and configured
# via the Lovable Cloud secrets store, not via .env.

VITE_PADDLE_ENVIRONMENT="sandbox"
VITE_PADDLE_CLIENT_TOKEN=""
VITE_PADDLE_PRICE_PRO_MONTHLY=""
VITE_PADDLE_PRICE_PRO_ANNUAL=""
VITE_PADDLE_PRICE_FOUNDER_LIFETIME=""

# Server-only Paddle secrets (configured via Lovable Cloud → Secrets, NOT here):
#   PADDLE_ENVIRONMENT          # "sandbox" until live verification is complete
#   PADDLE_WEBHOOK_SECRET       # used by the paddle-webhook edge function
#                               # to verify signatures against the raw body
