# Required environment variables for verdant-command-center-preview
# All variables are VITE_-prefixed and safe for client-side exposure.
#
# ⚠️  NEVER add SUPABASE_SERVICE_ROLE_KEY or any secret key here.
#     Only anon/publishable keys are permitted in client builds.

VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-anon-key>"
VITE_SUPABASE_PROJECT_ID="<supabase-project-ref>"

# ──────────────────────────────────────────────────────────────────────────────
# Paddle (SANDBOX ONLY)
# ──────────────────────────────────────────────────────────────────────────────
# Verdant is in sandbox/test mode for Paddle. Live charges are NOT enabled.
# Until live verification is complete, VITE_PADDLE_ENVIRONMENT MUST be "sandbox".
# The client-side checkout helper refuses to initialize if it is set to
# "live" or "production".
#
# VITE_PAYMENTS_CLIENT_TOKEN is the CANONICAL publishable client-side token
# for the Lovable-managed Paddle lane (see docs/billing.md). It is safe for
# client builds. The VITE_PADDLE_* set below is the deprecated BYO-era
# naming, retained only for older local setups.
#
# Never put server-only secrets (API keys, webhook signing secrets) in this
# file — they are configured via the Lovable Cloud secrets store, not .env.

VITE_PAYMENTS_CLIENT_TOKEN=""

# Deprecated BYO-era client vars (superseded by VITE_PAYMENTS_CLIENT_TOKEN):
VITE_PADDLE_ENVIRONMENT="sandbox"
VITE_PADDLE_CLIENT_TOKEN=""
VITE_PADDLE_PRICE_PRO_MONTHLY=""
VITE_PADDLE_PRICE_PRO_ANNUAL=""
VITE_PADDLE_PRICE_FOUNDER_LIFETIME=""

# Server-only Paddle secrets (configured via Lovable Cloud → Secrets, NOT here).
# Canonical Lovable lane (payments-webhook / paddle-portal-session /
# get-paddle-price — see docs/billing.md and docs/paddle-paid-launch-runbook.md):
#   PADDLE_SANDBOX_API_KEY            # gateway connection key (sandbox)
#   PADDLE_LIVE_API_KEY               # gateway connection key (live-enable slice only)
#   PAYMENTS_SANDBOX_WEBHOOK_SECRET   # webhook SIGNING secret (NOT the API key);
#   PAYMENTS_LIVE_WEBHOOK_SECRET      #   verifies Paddle-Signature on the RAW body
#   PAYMENTS_ENVIRONMENT              # "sandbox" until the reviewed live-enable slice
#   LOVABLE_API_KEY                   # Lovable gateway auth
# Legacy BYO audit sink (paddle-webhook only):
#   PADDLE_ENVIRONMENT          # "sandbox" until live verification is complete
#   PADDLE_WEBHOOK_SECRET       # used by the paddle-webhook edge function
#                               # to verify signatures against the raw body
