# Verdant EcoWitt Windows Testbench — Example env
# -----------------------------------------------
# Copy this file to `.env` and fill in real values locally.
# DO NOT commit `.env`. DO NOT paste real tokens into docs or chat.
#
# All values here are placeholders only — no real project IDs, no real
# tokens, no service-role keys, no anon keys, no access tokens.

VERDANT_INGEST_URL=https://YOUR_PROJECT.supabase.co/functions/v1/sensor-ingest-webhook
VERDANT_BRIDGE_TOKEN=vbt_REPLACE_WITH_REAL_TOKEN
VERDANT_TENT_ID=00000000-0000-0000-0000-000000000000

# Optional: override the listener port (default 8787)
# VERDANT_TESTBENCH_PORT=8787

# Optional: forcing live-source labeling for real EcoWitt gateway traffic.
# Leave unset for local testing. Demo/test payloads stay source="demo".
# VERDANT_FORWARD_MODE=live
